#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
oracle-browser-camoufox

Oracle-compatible-ish browser wrapper that keeps Oracle's prompt+file rendering,
but sends the rendered bundle through the working Camoufox ChatGPT bridge.

Supported flags:
  -p, --prompt <text>         Prompt text
  -f, --file <path...>        File/glob/directory; accepts one or more paths after a single flag
  -m, --model <model>         Model hint; if it contains 'pro', require Pro
  -t, --timeout <seconds>     Response timeout passed to chatgpt-direct (too-short explicit values may be auto-bumped for large rendered bundles)
      --allow-very-large-bundle
                              Permit live sends for extremely large rendered bundles (otherwise wrapper refuses and asks for narrower scope / explicit opt-in)
      --write-output <path>   Write final response to file
  -o, --output <path>         Alias for --write-output
      --cookies <path>        Custom cookie JSON path for chatgpt-direct
      --browser-cookie-path <path>
                              Compatibility alias for --cookies
      --chatgpt-url <url>     ChatGPT URL to open first (project/folder/custom GPT)
      --auth-only             Validate auth/pro state only; do not send a prompt
      --files-report          Show Oracle's file token usage during render
      --dry-run [mode]        Preview wrapper behavior without sending to ChatGPT (summary|json|full)
      --render                Alias for wrapper preview output (same as --dry-run full)
      --render-markdown       Alias for wrapper preview output (same as --dry-run full)
      --render-plain          Alias for wrapper preview output (same as --dry-run full)
      --copy-markdown         Copy preview/render output to clipboard (preview modes only)
      --json                  Emit JSON output from chatgpt-direct
  -v, --verbose               Verbose logs from chatgpt-direct
  -e, --engine <mode>         Accepts browser (default); api is rejected
  -s, --slug <words>          Accepted for compatibility; currently ignored
      --wait                  Accepted for compatibility; currently ignored
      --notify                Accepted for compatibility; currently ignored
      --no-notify             Accepted for compatibility; currently ignored
      --notify-sound          Accepted for compatibility; currently ignored
      --no-notify-sound       Accepted for compatibility; currently ignored
      --heartbeat <seconds>   Accepted for compatibility; currently ignored
      --force                 Accepted for compatibility; currently ignored
      --verbose-render        Accepted for compatibility; currently ignored
      --retain-hours <hours>  Accepted for compatibility; currently ignored
      --zombie-timeout <dur>  Accepted for compatibility; currently ignored
      --zombie-last-activity  Accepted for compatibility; currently ignored
      --debug-help            Show wrapper help and exit (compatibility alias)
      --browser-model-strategy <mode>
                              Accepted for compatibility; currently ignored
      --browser-attachments <mode>
                              Accepted for compatibility; currently ignored
      --browser-inline-files  Accepted for compatibility; wrapper always inlines rendered bundle
      --browser-bundle-files  Accepted for compatibility; currently ignored
      --require-auth          Require authenticated ChatGPT session (default)
      --no-require-auth       Allow guest/free mode
      --require-pro           Force Pro requirement regardless of model hint
  -h, --help                  Show help

Notes:
- This is a local fallback for headless server use when Oracle's Chromium/CDP
  browser engine is blocked by Cloudflare or browser-launch quirks.
- It uses `oracle --render --render-plain` to build the exact prompt+file bundle,
  then passes that bundle to `scripts/oracle/chatgpt-direct`.
EOF
}

prompt=""
model=""
timeout=""
write_output=""
cookies=""
chatgpt_url=""
engine="browser"
json=false
verbose=false
auth_only=false
files_report=false
dry_run_mode=""
render_alias_requested=false
copy_markdown=false
require_auth=true
require_pro="auto"
allow_very_large_bundle=false
declare -a files=()

declare -a passthrough=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    -p|--prompt)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      prompt="$2"
      shift 2
      ;;
    -f|--file)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      added_any=false
      shift
      while [[ $# -gt 0 && "$1" != -* ]]; do
        files+=("$1")
        added_any=true
        shift
      done
      if ! $added_any; then
        echo "Missing value for --file" >&2
        exit 2
      fi
      ;;
    -m|--model)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      model="$2"
      shift 2
      ;;
    -t|--timeout)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      timeout="$2"
      shift 2
      ;;
    --allow-very-large-bundle)
      allow_very_large_bundle=true
      shift
      ;;
    --write-output|-o|--output)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      write_output="$2"
      shift 2
      ;;
    --cookies|--browser-cookie-path)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      cookies="$2"
      shift 2
      ;;
    --chatgpt-url)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      chatgpt_url="$2"
      shift 2
      ;;
    --auth-only)
      auth_only=true
      shift
      ;;
    --files-report)
      files_report=true
      shift
      ;;
    --dry-run)
      if [[ $# -ge 2 && "$2" != -* ]]; then
        case "$2" in
          summary|json|full)
            dry_run_mode="$2"
            shift 2
            ;;
          *)
            echo "Invalid value for --dry-run: $2 (expected summary|json|full)" >&2
            exit 2
            ;;
        esac
      else
        dry_run_mode="summary"
        shift
      fi
      ;;
    --render|--render-markdown|--render-plain)
      render_alias_requested=true
      if [[ -n "$dry_run_mode" && "$dry_run_mode" != "full" ]]; then
        echo "$1 conflicts with --dry-run $dry_run_mode. Use either render-style preview or a single dry-run mode." >&2
        exit 2
      fi
      dry_run_mode="full"
      shift
      ;;
    --copy-markdown)
      copy_markdown=true
      shift
      ;;
    --json)
      json=true
      shift
      ;;
    -v|--verbose)
      verbose=true
      shift
      ;;
    -e|--engine)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      engine="$2"
      shift 2
      ;;
    -s|--slug)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      shift 2
      ;;
    --wait|--notify|--no-notify|--notify-sound|--no-notify-sound|--force|--verbose-render|--zombie-last-activity)
      shift
      ;;
    --heartbeat|--retain-hours|--zombie-timeout)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      shift 2
      ;;
    --debug-help)
      usage
      exit 0
      ;;
    --browser-model-strategy)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      shift 2
      ;;
    --browser-attachments)
      [[ $# -ge 2 ]] || { echo "Missing value for $1" >&2; exit 2; }
      case "$2" in
        auto|never|always) ;;
        *)
          echo "Invalid value for --browser-attachments: $2 (expected auto|never|always)" >&2
          exit 2
          ;;
      esac
      shift 2
      ;;
    --browser-inline-files)
      shift
      ;;
    --browser-bundle-files)
      shift
      ;;
    --remote-chrome|--remote-host|--remote-token|--browser-port)
      echo "Unsupported with scripts/oracle/oracle-browser: $1 targets Oracle's native Chrome/CDP or remote-browser paths, but this wrapper always uses the local Camoufox ChatGPT bridge instead." >&2
      exit 2
      ;;
    --models|--background|--no-background|--http-timeout|--base-url|--azure-endpoint|--azure-deployment|--azure-api-version)
      echo "Unsupported with scripts/oracle/oracle-browser: $1 is Oracle API-mode functionality, but this wrapper only provides browser-style execution via Camoufox." >&2
      exit 2
      ;;
    --require-auth)
      require_auth=true
      shift
      ;;
    --no-require-auth)
      require_auth=false
      shift
      ;;
    --require-pro)
      require_pro=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      if [[ "$1" != -* && -z "$prompt" ]]; then
        prompt="$1"
      else
        passthrough+=("$1")
      fi
      shift
      ;;
  esac
done

if [[ $# -gt 0 ]]; then
  passthrough+=("$@")
fi

if [[ -z "$prompt" && ! -t 0 ]]; then
  prompt="$(cat)"
fi

if [[ ${#passthrough[@]} -gt 0 ]]; then
  printf 'Unsupported with scripts/oracle/oracle-browser: unrecognized or unsupported argument(s): %s\n' "${passthrough[*]}" >&2
  printf 'Use --help to see the supported wrapper flags. This wrapper only covers the Oracle browser-style workflow on this server.\n' >&2
  exit 2
fi

engine_lc="$(printf '%s' "$engine" | tr '[:upper:]' '[:lower:]')"
if [[ "$engine_lc" != "browser" && -n "$engine_lc" ]]; then
  echo "This wrapper only supports browser-style execution. Use --engine browser (or omit it)." >&2
  exit 2
fi

if ! $auth_only && [[ -z "$prompt" ]]; then
  echo "Prompt required. Use --prompt, positional prompt, or stdin." >&2
  exit 2
fi

if [[ "$require_pro" == "auto" ]]; then
  model_lc="$(printf '%s' "$model" | tr '[:upper:]' '[:lower:]')"
  if [[ "$model_lc" == *pro* ]]; then
    require_pro=true
  else
    require_pro=false
  fi
fi

if $copy_markdown && [[ -z "$dry_run_mode" ]]; then
  echo "Unsupported with scripts/oracle/oracle-browser: --copy-markdown is only supported with preview/render modes (--dry-run, --render, --render-markdown, --render-plain)." >&2
  exit 2
fi

render_file="$(mktemp)"
trap 'rm -f "$render_file"' EXIT

recommend_timeout_floor() {
  local final_len="$1"
  if [[ ! "$final_len" =~ ^[0-9]+$ ]]; then
    echo 0
  elif (( final_len >= 20000 )); then
    echo 900
  elif (( final_len >= 10000 )); then
    echo 600
  else
    echo 0
  fi
}

bundle_guidance() {
  local final_len="$1"
  if [[ ! "$final_len" =~ ^[0-9]+$ ]]; then
    echo ""
  elif (( final_len >= 40000 )); then
    echo "very large rendered bundle — expect long Extended Pro thinking; consider narrowing files or inspecting --dry-run json / --files-report first"
  elif (( final_len >= 20000 )); then
    echo "large rendered bundle — expect Extended Pro thinking; use --dry-run json or --files-report if you want to inspect size before sending"
  elif (( final_len >= 10000 )); then
    echo "moderately large rendered bundle — longer thinking time is normal"
  else
    echo ""
  fi
}

copy_preview_to_clipboard() {
  local output="$1"
  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$output" | pbcopy
  elif command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$output" | wl-copy
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$output" | xclip -selection clipboard
  elif command -v xsel >/dev/null 2>&1; then
    printf '%s' "$output" | xsel --clipboard --input
  else
    echo "Unsupported with scripts/oracle/oracle-browser: --copy-markdown requires a clipboard backend (pbcopy, wl-copy, xclip, or xsel), and none is available on this host." >&2
    return 2
  fi
}

emit_preview_output() {
  local output="$1"
  printf '%s\n' "$output"
  if [[ -n "$write_output" ]]; then
    printf '%s\n' "$output" > "$write_output"
  fi
  if $copy_markdown; then
    copy_preview_to_clipboard "$output"
  fi
}

build_dry_run_output() {
  local rendered_bundle="$1"
  local final_prompt="$2"
  local requested_timeout="$3"
  local effective_timeout="$4"
  local timeout_floor="$5"
  local timeout_auto_bumped="$6"
  local timeout_adjustment="$7"
  local bundle_guidance_note="$8"
  local very_large_bundle="$9"
  local allow_very_large_bundle_effective="${10}"
  local file_count="${#files[@]}"
  local mode="${dry_run_mode:-summary}"
  local require_pro_effective="${require_pro}"
  case "$mode" in
    full)
      if $auth_only; then
        printf '%s\n' "oracle-browser dry run (auth-only): no prompt would be sent; wrapper would only validate auth/pro state."
      else
        printf '%s\n' "$final_prompt"
      fi
      ;;
    summary)
      cat <<EOF
oracle-browser dry run
- authOnly: $auth_only
- promptProvided: $([[ -n "$prompt" ]] && echo true || echo false)
- fileCount: $file_count
- model: ${model:-"(none)"}
- requireAuth: $require_auth
- requirePro: $require_pro_effective
- chatgptUrl: ${chatgpt_url:-https://chatgpt.com}
- filesReport: $files_report
- jsonOutput: $json
- requestedTimeout: ${requested_timeout:-"(bridge default)"}
- effectiveTimeout: ${effective_timeout:-21600}
- timeoutHeuristicFloor: ${timeout_floor:-0}
- timeoutAutoBumped: $timeout_auto_bumped
- timeoutAdjustment: ${timeout_adjustment:-"(none)"}
- bundleGuidance: ${bundle_guidance_note:-"(none)"}
- veryLargeBundle: $very_large_bundle
- allowVeryLargeBundle: $allow_very_large_bundle_effective
- writeOutput: ${write_output:-"(none)"}
- copyMarkdown: $copy_markdown
EOF
      ;;
    json)
      python3 - <<'PY' \
        "$auth_only" "$([[ -n "$prompt" ]] && echo true || echo false)" "$file_count" \
        "$model" "$require_auth" "$require_pro_effective" "${chatgpt_url:-https://chatgpt.com}" \
        "$files_report" "$json" "$requested_timeout" "$effective_timeout" "$timeout_floor" "$timeout_auto_bumped" "$timeout_adjustment" "$bundle_guidance_note" "$very_large_bundle" "$allow_very_large_bundle_effective" "$write_output" "$cookies" "$copy_markdown" "${#rendered_bundle}" "${#final_prompt}"
import json, sys
(auth_only, prompt_provided, file_count, model, require_auth, require_pro, chatgpt_url,
 files_report, json_output, requested_timeout, effective_timeout, timeout_floor, timeout_auto_bumped,
 timeout_adjustment, bundle_guidance_note, very_large_bundle, allow_very_large_bundle_effective,
 write_output, cookies, copy_markdown, rendered_len, final_len) = sys.argv[1:23]
print(json.dumps({
  "status": "ok",
  "mode": "dry-run",
  "wrapper": "oracle-browser-camoufox",
  "plan": {
    "authOnly": auth_only == "true",
    "promptProvided": prompt_provided == "true",
    "fileCount": int(file_count),
    "model": model,
    "requireAuth": require_auth == "true",
    "requirePro": require_pro == "true",
    "chatgptUrl": chatgpt_url,
    "filesReport": files_report == "true",
    "jsonOutput": json_output == "true",
    "requestedTimeout": int(requested_timeout) if requested_timeout else None,
    "effectiveTimeout": int(effective_timeout) if effective_timeout else 21600,
    "bridgeDefaultTimeoutSeconds": 21600,
    "timeoutHeuristicFloor": int(timeout_floor) if timeout_floor else 0,
    "timeoutAutoBumped": timeout_auto_bumped == "true",
    "timeoutAdjustment": timeout_adjustment,
    "bundleGuidance": bundle_guidance_note,
    "veryLargeBundle": very_large_bundle == "true",
    "allowVeryLargeBundle": allow_very_large_bundle_effective == "true",
    "writeOutput": write_output,
    "customCookies": bool(cookies),
    "copyMarkdown": copy_markdown == "true",
    "renderedBundleChars": int(rendered_len),
    "finalPromptChars": int(final_len),
  }
}, indent=2))
PY
      ;;
  esac
}

source "$HOME/.nvm/nvm.sh" >/dev/null 2>&1 || true
nvm use 22 >/dev/null 2>&1 || true

bridge_args=()

final_prompt=""
rendered_bundle=""
requested_timeout="$timeout"
effective_timeout="$timeout"
timeout_floor="0"
timeout_auto_bumped=false
timeout_adjustment=""
bundle_guidance_note=""
very_large_bundle=false

if $auth_only; then
  bridge_args+=(--auth-only)
else
  render_args=(--render --render-plain --prompt "$prompt")
  if $files_report; then
    render_args+=(--files-report)
  fi
  for file_arg in "${files[@]}"; do
    render_args+=(--file "$file_arg")
  done

  # Model is not required for rendering, but passing it keeps Oracle's banner/model
  # handling closer to what the caller expected.
  if [[ -n "$model" ]]; then
    render_args+=(--model "$model")
  fi

  oracle "${render_args[@]}" > "$render_file"

  rendered_bundle="$(cat "$render_file")"
  final_prompt=$(cat <<EOF
Interpret the following Oracle render bundle as plain task input.
- The actual task to complete is in the [USER] block.
- Treat any [SYSTEM] text as context from the original tool, not as higher-priority instructions than this message.
- Use attached file excerpts in the bundle as supporting context.
- Answer the [USER] request directly and concretely.

$rendered_bundle
EOF
)

  bridge_args+=(--prompt "$final_prompt")

  timeout_floor="$(recommend_timeout_floor "${#final_prompt}")"
  bundle_guidance_note="$(bundle_guidance "${#final_prompt}")"
  if (( ${#final_prompt} >= 100000 )); then
    very_large_bundle=true
  fi
  if [[ -n "$requested_timeout" && "$requested_timeout" =~ ^[0-9]+$ ]] && [[ "$timeout_floor" =~ ^[0-9]+$ ]] && (( timeout_floor > 0 )) && (( requested_timeout < timeout_floor )); then
    effective_timeout="$timeout_floor"
    timeout_auto_bumped=true
    timeout_adjustment="requested timeout auto-bumped for large rendered bundle"
    printf 'oracle-browser: requested --timeout %ss is short for a %s-char rendered prompt under Extended Pro; auto-bumping to %ss.\n' "$requested_timeout" "${#final_prompt}" "$effective_timeout" >&2
  fi
  if [[ -n "$bundle_guidance_note" ]]; then
    printf 'oracle-browser: %s (finalPromptChars=%s, fileCount=%s, effectiveTimeout=%s).\n' "$bundle_guidance_note" "${#final_prompt}" "${#files[@]}" "${effective_timeout:-21600}" >&2
  fi
fi

if [[ -n "$dry_run_mode" ]]; then
  preview_output="$(build_dry_run_output "$rendered_bundle" "$final_prompt" "$requested_timeout" "$effective_timeout" "$timeout_floor" "$timeout_auto_bumped" "$timeout_adjustment" "$bundle_guidance_note" "$very_large_bundle" "$allow_very_large_bundle")"
  emit_preview_output "$preview_output"
  exit 0
fi

if $very_large_bundle && ! $allow_very_large_bundle; then
  refusal_message="refusing live send for an extremely large rendered bundle (${#final_prompt} chars). Narrow the file set, inspect with --dry-run json / --files-report first, or pass --allow-very-large-bundle to proceed explicitly."
  if $json; then
    python3 - <<'PY' \
      "$refusal_message" "$requested_timeout" "$effective_timeout" "$timeout_floor" "$timeout_auto_bumped" "$timeout_adjustment" "$bundle_guidance_note" "$very_large_bundle" "$allow_very_large_bundle" "${#rendered_bundle}" "${#final_prompt}" "${#files[@]}" "$model" "$require_auth" "$require_pro" "${chatgpt_url:-https://chatgpt.com}"
import json, sys
(message, requested_timeout, effective_timeout, timeout_floor, timeout_auto_bumped,
 timeout_adjustment, bundle_guidance_note, very_large_bundle, allow_very_large_bundle,
 rendered_len, final_len, file_count, model, require_auth, require_pro, chatgpt_url) = sys.argv[1:17]
print(json.dumps({
  "status": "error",
  "error": {
    "code": "very-large-bundle-refused",
    "message": message,
  },
  "wrapper": "oracle-browser-camoufox",
  "plan": {
    "fileCount": int(file_count),
    "model": model,
    "requireAuth": require_auth == "true",
    "requirePro": require_pro == "true",
    "chatgptUrl": chatgpt_url,
    "requestedTimeout": int(requested_timeout) if requested_timeout else None,
    "effectiveTimeout": int(effective_timeout) if effective_timeout else 21600,
    "timeoutHeuristicFloor": int(timeout_floor) if timeout_floor else 0,
    "timeoutAutoBumped": timeout_auto_bumped == "true",
    "timeoutAdjustment": timeout_adjustment,
    "bundleGuidance": bundle_guidance_note,
    "veryLargeBundle": very_large_bundle == "true",
    "allowVeryLargeBundle": allow_very_large_bundle == "true",
    "renderedBundleChars": int(rendered_len),
    "finalPromptChars": int(final_len),
  }
}, indent=2))
PY
  else
    printf 'oracle-browser: %s\n' "$refusal_message" >&2
  fi
  exit 2
fi

if [[ -n "$effective_timeout" ]]; then
  bridge_args+=(--timeout "$effective_timeout")
fi
if [[ -n "$write_output" ]]; then
  bridge_args+=(--output "$write_output")
fi
if [[ -n "$cookies" ]]; then
  bridge_args+=(--cookies "$cookies")
fi
if [[ -n "$chatgpt_url" ]]; then
  bridge_args+=(--chatgpt-url "$chatgpt_url")
fi
if $json; then
  bridge_args+=(--json)
fi
if $verbose; then
  bridge_args+=(--verbose)
fi
if $require_auth; then
  bridge_args+=(--require-auth)
fi
if [[ "$require_pro" == true ]]; then
  bridge_args+=(--require-pro)
fi

exec "$SCRIPT_DIR/chatgpt-direct" "${bridge_args[@]}"
