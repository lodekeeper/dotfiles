    {
      "id": "b43e13",
      "file": "packages/beacon-node/src/api/rest/base.ts",
      "line": 93,
      "severity": "major",
      "reviewer": "lodekeeper",
      "body": "Good catch \u2014 raised the cap to `NUMBER_OF_COLUMNS` (128) in c1fa18ec1b so a full-custody `getDebugDataColumnSidecars` request (columns 0..127) parses as an array. Kept it a single global limit rather than route-specific: the route schemas set no per-request `maxItems`, so the qs `arrayLimit` is the only cap, and it isn't a DoS boundary (`parseArrays: false` disables index-based sparse arrays; URL/header size bounds total input).",
      "status": "open",
      "addressed_commit": null,
      "note": null,
      "source": {
        "kind": "github-review-comment",
        "id": "3604995282",
        "repo": "ChainSafe/lodestar",
        "pr": 9673,
        "url": "https://github.com/ChainSafe/lodestar/pull/9673#discussion_r3604995282"
      },
      "created": "2026-07-20T15:33:56Z",
      "updated": "2026-07-20T15:33:56Z",
      "matched_findings": [
        "8c2d05"
      ]
    },
    {
