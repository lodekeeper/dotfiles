# 1) Generated Kurtosis artifact dumps (keep configs, ignore tmp generated payloads)
kurtosis/tmp-*/

# 2) Python bytecode/cache artifacts
**/__pycache__/
*.pyc

# 3) Runtime state DBs (example: web-search cache/rate-limit state)
skills/web-search/state/*.db

# 4) Never commit on-disk credentials (they live outside the repo; defense-in-depth if one ever lands inside)
*bn-basic-auth*
*-cookies.json
*.cred
